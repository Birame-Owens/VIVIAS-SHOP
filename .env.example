# ==========================================
# VIVIAS-SHOP Environment Configuration
# ==========================================
# Copy this file to .env and update with your values

# Application
APP_NAME="VIVIAS SHOP"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Locale
APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

# Server
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Ports
APP_PORT=8000
FRONTEND_PORT=5173
DB_PORT=5432
REDIS_PORT=6379

# Database (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=VIVIAS
DB_USERNAME=postgres
DB_PASSWORD=password

# Session
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Broadcasting
BROADCAST_CONNECTION=log

# File Storage
FILESYSTEM_DISK=s3

# Cache & Queue
CACHE_DRIVER=redis
CACHE_STORE=redis
QUEUE_CONNECTION=database

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@vivias-shop.com"
MAIL_FROM_NAME="${APP_NAME}"

# Optional Storage Configuration
# FILESYSTEM_DISK=local or s3

# Stripe Payment
STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx

# NexPay Payment
NEXPAY_API_KEY=your_nexpay_key
NEXPAY_URL=https://api.nexpay.com

# PayTech Payment
PAYTECH_API_KEY=your_paytech_key
PAYTECH_URL=https://api.paytech.com

# WhatsApp Integration
WHATSAPP_API_URL=
WHATSAPP_API_KEY=

# Sanctum
SANCTUM_STATEFUL_DOMAINS="localhost:5173,127.0.0.1:5173"

# Frontend
REACT_APP_API_URL=http://localhost:8000/api
VITE_APP_NAME="${APP_NAME}"
VITE_API_URL=http://localhost:8000/api
