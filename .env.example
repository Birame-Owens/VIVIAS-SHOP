APP_NAME="VIVIAS SHOP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001
FRONTEND_URL=http://localhost:8001
TELESCOPE_ENABLED=false

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

APP_PORT=8001
FRONTEND_PORT=5173
DB_PORT=5432
REDIS_PORT=6379

# Local install: use 127.0.0.1.
# Docker install: docker-compose.yml overrides DB_HOST and REDIS_HOST automatically.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_DATABASE=VIVIAS
DB_USERNAME=postgres
DB_PASSWORD=password

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

CACHE_STORE=database
CACHE_DRIVER=database
QUEUE_CONNECTION=database

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@vivias-shop.local"
MAIL_FROM_NAME="${APP_NAME}"

STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

NEXPAY_API_KEY=
NEXPAY_URL=

PAYTECH_API_KEY=
PAYTECH_URL=

WHATSAPP_API_URL=
WHATSAPP_API_KEY=

SANCTUM_STATEFUL_DOMAINS=localhost:8001,127.0.0.1:8001,localhost:5173,127.0.0.1:5173

REACT_APP_API_URL=http://localhost:8001/api
VITE_APP_NAME="${APP_NAME}"
VITE_API_URL=http://localhost:8001/api
